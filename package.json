{
  "name": "crossword-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch server.ts",
    "dev:3000": "set PORT=3000&& tsx watch server.ts",
    "dev:3001": "set PORT=3001&& tsx watch server.ts",
    "dev:3002": "set PORT=3002&& tsx watch server.ts",
    "build": "next build",
    "build:server": "tsup server.ts --format cjs --out-dir dist --platform node --target node20",
    "build:all": "npm run build && npm run build:server",
    "start": "node dist/server.js",
    "start:3000": "set PORT=3000&& node dist/server.js",
    "start:3001": "set PORT=3001&& node dist/server.js",
    "start:3002": "set PORT=3002&& node dist/server.js",
    "lint": "next lint",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^5.10.0",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-progress": "^1.0.3",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@socket.io/redis-adapter": "^8.2.1",
    "bullmq": "^5.1.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "framer-motion": "^11.0.0",
    "ioredis": "^5.3.2",
    "lucide-react": "^0.330.0",
    "next": "^16.1.6",
    "papaparse": "^5.4.1",
    "qrcode.react": "^3.1.0",
    "react": "^18.2.0",
    "react-confetti": "^6.1.0",
    "react-dom": "^18.2.0",
    "react-hot-toast": "^2.4.1",
    "socket.io": "^4.6.1",
    "socket.io-client": "^4.6.1",
    "socket.io-redis": "^6.1.1",
    "tailwind-merge": "^2.2.0",
    "uuid": "^9.0.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/papaparse": "^5.3.14",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/uuid": "^9.0.0",
    "autoprefixer": "^10.4.17",
    "postcss": "^8.4.35",
    "prisma": "^5.10.0",
    "tailwindcss": "^3.4.1",
    "tsup": "^8.5.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
