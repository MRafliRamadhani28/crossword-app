// prisma/schema.prisma

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Room {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  hostName    String
  capacity    Int      @default(65)
  status      RoomStatus @default(WAITING)
  config      Json?
  currentPuzzleId String?  @unique
  currentPuzzle   Puzzle?  @relation("RoomCurrentPuzzle", fields: [currentPuzzleId], references: [id], onDelete: SetNull)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  players     Player[]
  puzzles     Puzzle[]

  @@index([code])
  @@index([status])
}

model Player {
  id        String   @id @default(cuid())
  name      String
  avatar    String?   // emoji avatar
  socketId  String?
  points    Int      @default(0)
  rank      Int?
  isActive  Boolean  @default(true)
  joinedAt  DateTime @default(now())
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  answers   Answer[]

  @@index([roomId])
  @@index([points])
}

model Puzzle {
  id          String      @id @default(cuid())
  question    String
  answer      String
  hint        String?
  clueNumber  Int
  orientation Orientation
  row         Int
  col         Int
  length      Int
  isOpened    Boolean     @default(false)
  isRevealed  Boolean     @default(false)
  openedAt    DateTime?
  timeLimit   Int         @default(30)  // seconds
  basePoints  Int         @default(100)
  roomId      String
  room        Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  answers     Answer[]
  currentRoom Room?       @relation("RoomCurrentPuzzle")

  @@index([roomId])
  @@index([clueNumber])
}

model Answer {
  id          String   @id @default(cuid())
  content     String
  isCorrect   Boolean  @default(false)
  points      Int      @default(0)
  timeBonus   Int      @default(0)
  submittedAt DateTime @default(now())
  playerId    String
  player      Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  puzzleId    String
  puzzle      Puzzle   @relation(fields: [puzzleId], references: [id], onDelete: Cascade)

  @@unique([playerId, puzzleId])
  @@index([puzzleId])
  @@index([playerId])
}

enum RoomStatus {
  WAITING
  PLAYING
  FINISHED
}

enum Orientation {
  ACROSS
  DOWN
}
